{
  "name": "coding-agent",
  "displayName": "Coding Agent",
  "description": "A prototype VS Code coding-agent extension inspired by OpenCode's agent loop architecture.",
  "version": "0.0.1",
  "private": true,
  "publisher": "local",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:codingAgent.openPanel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codingAgent.openPanel",
        "title": "Coding Agent: Open Panel"
      }
    ]
  },
  "scripts": {
    "compile": "npm run compile:extension && npm run typecheck:webview && npm run compile:webview",
    "compile:extension": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc -p ./tsconfig.json",
    "typecheck:webview": "tsc -p ./tsconfig.webview.json",
    "compile:webview": "npm run compile:webview:css && npm run compile:webview:js",
    "compile:webview:css": "tailwindcss -i ./src/webview/styles.css -o ./dist/webview/index.css --minify",
    "compile:webview:js": "esbuild ./src/webview/index.tsx --bundle --format=iife --platform=browser --jsx=automatic --outfile=./dist/webview/index.js",
    "test": "npm run compile && node dist/test/run.js",
    "watch": "tsc -watch -p ./tsconfig.json",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.100.0",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}
